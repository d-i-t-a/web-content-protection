{
  "name": "@d-i-t-a/web-content-protection",
  "version": "1.1.0",
  "description": "Client-side content protection for web-based ebook readers. Drag prevention, copy protection, print blocking, text obfuscation, DevTools detection, and more.",
  "author": "AM Consulting LLC (DITA)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "demo": "npm run build && npx serve . -l 3456 --no-clipboard",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "optionalDependencies": {
    "browserslist-useragent-regexp": "^4.1.3",
    "devtools-detector": "^2.0.14"
  },
  "keywords": [
    "drm",
    "content-protection",
    "ebook",
    "reader",
    "copy-protection",
    "print-protection",
    "obfuscation",
    "web-reader"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/d-i-t-a/web-content-protection"
  }
}
